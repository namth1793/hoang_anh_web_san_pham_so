# ── Server ─────────────────────────────────────────────────────
PORT=5000

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=doi_thanh_chuoi_bi_mat_cua_ban_tai_day

# ── CORS — URL frontend (nhiều URL cách nhau bằng dấu phẩy) ───
FRONTEND_URL=https://your-app.vercel.app

# ── Email (nodemailer / Gmail App Password) ─────────────────────
# Tạo App Password: Google Account → Security → 2-Step → App passwords
MAIL_USER=your_email@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
# Email nhận thông báo đơn hàng & form liên hệ
ADMIN_EMAIL=admin@your-domain.com

# ── VNPay QR ────────────────────────────────────────────────────
# Đăng ký sandbox: https://sandbox.vnpayment.vn/devreg
# Sau đăng ký sẽ nhận TMN_CODE + HASH_SECRET qua email

# Mã terminal do VNPay cấp
VNP_TMN_CODE=XXXXXXXX

# Chuỗi bí mật ký HMAC-SHA512 do VNPay cấp
VNP_HASH_SECRET=your_vnpay_hash_secret_here

# URL cổng thanh toán
# Sandbox : https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production: https://pay.vnpay.vn/vpcpay/vpcpay.html
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# URL frontend VNPay redirect sau khi thanh toán (trình duyệt người dùng)
VNP_RETURN_URL=https://your-app.vercel.app/checkout

# ── VNPay IPN (Webhook) ─────────────────────────────────────────
# Cấu hình URL webhook trong VNPay merchant portal (KHÔNG phải trong .env)
# URL phải công khai — dùng ngrok khi dev local:
#   ngrok http 5000  →  https://xxxx.ngrok.io/api/payment/webhook
# Production: https://your-backend.railway.app/api/payment/webhook
